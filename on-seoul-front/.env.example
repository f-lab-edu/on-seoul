# 브라우저에서 직접 API 서비스로 요청할 때 사용 (클라이언트 노출)
NEXT_PUBLIC_API_BASE_URL=

# Route Handler / 서버 컴포넌트에서 API 서비스로 요청할 때 사용 (서버 전용)
# 내부망 라우팅이 가능하면 내부 호스트로 설정. 그렇지 않으면 NEXT_PUBLIC_API_BASE_URL과 동일 값.
API_BASE_URL=

# OAuth 진입 베이스 URL (프로바이더 경로 제외, 예: https://api.example.com/oauth2/authorization)
# 로그인 페이지가 프로바이더 id(google/kakao)를 뒤에 덧붙인다.
NEXT_PUBLIC_OAUTH_BASE_URL=
