# on-seoul-agent 환경변수 예시 (.env 로 복사해 채운다. .env 는 커밋 금지)

# --- Database (PostgreSQL) ---
# on_ai DB: AI 서비스 전용 (service_embeddings, chat_agent_traces) — CRUD 권한
ON_AI_DATABASE_URL=postgresql+asyncpg://on_ai_app:CHANGEME@localhost:5432/on_ai
# on_data DB: 정형 데이터 — SELECT 전용 계정
ON_DATA_DATABASE_URL=postgresql+asyncpg://on_data_reader:CHANGEME@localhost:5432/on_data

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- LLM (Gemini 우선, GPT 폴백) ---
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
OPENAI_API_KEY=

# --- Admin ---
ADMIN_INTERNAL_TOKEN=

# --- OpenTelemetry (인프라 계측 → SigNoz, 기본 off) ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://on-seoul-signoz:4317
OTEL_SERVICE_NAME=on-seoul-agent
OTEL_ENVIRONMENT=local

# --- Langfuse (LLM 관측가능성 → Langfuse Cloud, 기본 off) ---
# 별개 파이프라인으로 OTel 과 공존. 그래프 LLM I/O·토큰·비용 관측.
# 키는 Langfuse Cloud 프로젝트 설정에서 발급. 커밋 금지.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_BASE_URL=https://cloud.langfuse.com
