# =============================================================
# on-seoul 환경변수 예시
# 복사 후 .env 로 저장하고 실제 값을 채워 사용한다.
# .env 파일은 절대 커밋하지 않는다.
# =============================================================

# ── Redis 접속 ───────────────────────────────────────────────
# bridge 네트워크(on-seoul-net) 합류 후에는 컨테이너 이름으로 직접 통신한다.
# REDIS_HOST=on-seoul-redis   # on-seoul-net bridge 사용 시 (권장)
# REDIS_PORT=6379             # 컨테이너 내부 포트 (bridge 사용 시)
# REDIS_HOST=<서버DNS>        # 외부 DNS 사용 시 (레거시, 비권장 — JVM DNS 캐시 stale IP 위험)
# REDIS_PORT=49879            # 호스트 매핑 포트 (외부 DNS 사용 시)
REDIS_PASSWORD=               # 필수

# ── DB 접속 ───────────────────────────────────────────────────
# Spring Boot 런타임과 jOOQ codegen이 동일 변수를 사용한다.
# jOOQ Q-클래스 재생성: DB 기동 후 ./gradlew :notification:jooqCodegen
DB_URL=jdbc:postgresql://localhost:5432/on_data   # 필수
DB_USERNAME=on_data_app                           # 필수
DB_PASSWORD=                                      # 필수

ON_DATA_APP_PASSWORD=           # on_data_app 계정 비밀번호 (DB_PASSWORD 와 동일)
ON_AI_APP_PASSWORD=             # on_ai_app 계정 비밀번호
ON_AI_READER_PASSWORD=          # on_ai_reader 계정 비밀번호

# ── Knock 알림 서비스 ─────────────────────────────────────────
# Knock 대시보드 > Developers > API Keys > Secret key
# Development 환경: sk_test_...  |  Production 환경: sk_...
# 가이드: on-seoul-api/docs/knock-integration-guide.md
KNOCK_API_KEY=                  # 필수. 미설정 시 앱 시작 실패

# ── PII 암호화 ────────────────────────────────────────────────
# 각각 독립된 32바이트 랜덤 키. 두 값이 달라야 한다.
# 생성 명령: openssl rand -hex 32
# 주의: 키를 잃으면 암호화된 데이터 복구 불가. 안전한 곳에 보관할 것.
APP_AES_KEY=                    # 필수. AES-256-GCM 암호화/복호화 키
APP_BLIND_IDX_KEY=              # 필수. Blind Index(HMAC-SHA256) 키

# ── OpenTelemetry (api·agent 공유, SigNoz) ───────────────────
# 공유분은 .env.deploy 에 설정(api·agent 동일 백엔드). 미설정 시 계측 완전 no-op(기본 off).
# on-seoul-net 브리지에서 on-seoul-signoz 로 직접 통신.
OTEL_ENABLED=false                                       # 활성화: true
OTEL_EXPORTER_OTLP_ENDPOINT=http://on-seoul-signoz:4317  # 트레이스/로그 gRPC
OTEL_EXPORTER_OTLP_PROTOCOL=grpc                         # 기본 grpc
OTEL_ENVIRONMENT=prod                                    # local | prod
OTEL_LOGS_EXPORTER=otlp                                  # Java Agent 로그 export
# OTEL_SERVICE_NAME 은 .env.api / .env.agent 에서 서비스별로 지정
# Micrometer 프레임워크 메트릭은 http://on-seoul-signoz:4318 (HTTP/protobuf) 로 export (application.yml, Task 8)
# OTEL_EXPORTER_OTLP_TIMEOUT=10                         # 선택, 기본 10초
# OTEL_METRIC_EXPORT_INTERVAL_MS=60000                  # 선택, 기본 60000ms

# ── (선택) 로컬 Knock 연동 테스트용 ──────────────────────────
# KnockNotificationAdapterIntegrationTest 실행 시만 필요
# 미설정 시 해당 테스트는 자동 스킵(assumeTrue 기반)
# KNOCK_TEST_USER_ID=
# KNOCK_TEST_EMAIL=
# KNOCK_TEST_PHONE=
