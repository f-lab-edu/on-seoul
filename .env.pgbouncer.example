# =============================================================
# PgBouncer 환경변수 예시
# 복사 후 .env.pgbouncer 로 저장하고 실제 값을 채워 사용한다.
# .env.pgbouncer 파일은 절대 커밋하지 않는다.
#
# 풀 정의는 infra/pgbouncer/pgbouncer.ini 에서 관리한다.
# 이 파일의 변수들은 pgbouncer.ini 내 ${VAR} 플레이스홀더를
# edoburu/pgbouncer entrypoint(envsubst)가 치환하는 데 사용된다.
# =============================================================

# ── PG 서버 접속 정보 ─────────────────────────────────────────
# 관리형 PG(RDS 등)는 엔드포인트 DNS를 사용한다.
PGBOUNCER_PG_HOST=<pg-host-or-container-name>
PGBOUNCER_PG_PORT=5432

# ── DB 유저/자격증명 (A 방식에선 .ini 에서 미사용) ──────────────
# A 방식(클라이언트 롤 pass-through)에서는 pgbouncer.ini [databases] 에 user= 를
# 박지 않는다. PgBouncer 는 클라이언트가 접속 URL 로 제시한 롤
# (on_ai_app / on_data_app / on_data_reader) 그대로 PG 에 로그인한다.
# 따라서 아래 USER/PASSWORD 변수들은 .ini 의 ${VAR} 치환에 더 이상 쓰이지 않는다.
#
# 자격증명(서버 SCRAM 로그인 verifier)의 단일 출처는 infra/pgbouncer/userlist.txt 이다
# (연결하는 3롤 모두: on_ai_app, on_data_app, on_data_reader). 비밀번호/USER 를
# 여기서 관리하지 않는다.
#
# 아래 변수는 호환/참고용으로만 남긴다(.ini envsubst 대상 아님). 불필요하면 삭제 가능.
# PGBOUNCER_ON_AI_USER=on_ai_app        # 미사용 (롤은 클라이언트 URL 에서 옴)
# PGBOUNCER_ON_AI_PASSWORD=...          # 미사용 (자격증명 출처: userlist.txt)
# PGBOUNCER_ON_DATA_USER=on_data_app    # 미사용 (롤은 클라이언트 URL 에서 옴)
# PGBOUNCER_ON_DATA_PASSWORD=...        # 미사용 (자격증명 출처: userlist.txt)

# ── 운영 환경 포트 노출 주의 ──────────────────────────────────
# docker-compose-pgbouncer.yml 의 ports 항목은 로컬 개발 디버깅 전용이다.
# 운영 배포 시에는 ports 항목을 제거하여 pgbouncer 포트가
# 호스트 외부에 노출되지 않도록 한다.
# 앱 컨테이너는 on-seoul-net 내부 DNS(pgbouncer:5432)로 접근한다.

# ── 프로덕션 시크릿 출처 가이드 ──────────────────────────────
# AWS  : Parameter Store (SecureString) 또는 Secrets Manager
# GCP  : Secret Manager
# Vault: vault kv get secret/on-seoul/pgbouncer
# GitHub Actions: secret 으로 userlist.txt(3롤 verifier)를 생성/주입
# (A 방식: 자격증명은 PGBOUNCER_* 환경변수가 아니라 userlist.txt 가 단일 출처)
